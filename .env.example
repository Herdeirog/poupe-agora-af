# ==============================================
# CONFIGURAÇÃO PARA VERCEL / PRODUÇÃO
# ==============================================
# Copie este arquivo para .env.local e preencha os valores
# Na Vercel, configure estas variáveis no Dashboard:
# Settings -> Environment Variables

# Supabase - Obrigatórias (prefixo VITE_ para acesso no frontend)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# ==============================================
# IMPORTANTE PARA VERCEL:
# ==============================================
# 1. Não commite o arquivo .env com valores reais
# 2. Configure as variáveis no Dashboard da Vercel:
#    - Settings -> Environment Variables
# 3. Use os mesmos nomes de variáveis (com prefixo VITE_)
# 4. Selecione os ambientes: Production, Preview, Development
# ==============================================
